{
	"name": "wktree",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "bun test tests",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"build": "bun run ./scripts/build-bin.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"typescript": "^5.0.0"
	},
	"lint-staged": {
		"**/*.{json,ts}": "biome check --write --no-errors-on-unmatched",
		"**/*.nu": [
			"nufmt",
			"sh -c 'for file do nu -c \"nu-check --debug --as-module $file\"; done' --"
		]
	}
}
